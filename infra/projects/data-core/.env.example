APP_ENV=production
API_PORT=8000
DATABASE_URL=postgresql+psycopg://data_core_user:change-me@postgres:5432/data_core_db
REDIS_URL=redis://:change-me@redis:6379/2
CACHE_ENABLED=true
API_KEY_ENABLED=true
API_KEY=change-me
ALERT_WEBHOOK_URL=
POUPI_LEGACY_BACKEND_DIR=/app/domains/poupi_baby/backend
WORKER_PIPELINE_INTERVAL_SECONDS=300
# SCHEDULER_COLLECTORS_ENABLED: coleta raw a cada N min por collector registado
SCHEDULER_COLLECTORS_ENABLED=true
# SCHEDULER_PIPELINE_ENABLED: OBRIGATÓRIO true em prod — normaliza raw → normalized_products
# Se false, /api/v1/poupi-baby/price-feed retorna count=0 permanentemente
SCHEDULER_PIPELINE_ENABLED=true
# SCHEDULER_DOMAIN_JOBS_ENABLED: habilita run_ecommerce_url_targets_job a cada 2h
SCHEDULER_DOMAIN_JOBS_ENABLED=true
