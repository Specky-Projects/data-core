# Global infra example. Copy to infra/.env on the server and never commit real values.

COMPOSE_PROJECT_NAME=multi_project_infra
INFRA_DOMAIN=infra.example.com
TZ=America/Sao_Paulo

# Shared PostgreSQL
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=change-me-long-random-admin-password
POSTGRES_INTERNAL_PORT=5432

# Per-project database credentials. Rotate before production.
POUPI_BABY_DB=poupi_baby_db
POUPI_BABY_DB_USER=poupi_baby_user
POUPI_BABY_DB_PASSWORD=change-me

DATA_CORE_DB=data_core_db
DATA_CORE_DB_USER=data_core_user
DATA_CORE_DB_PASSWORD=change-me

TRADING_BOT_DB=trading_bot_db
TRADING_BOT_DB_USER=trading_bot_user
TRADING_BOT_DB_PASSWORD=change-me

ANALYTICS_DB=analytics_db
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=change-me

# Shared Redis
REDIS_IMAGE=redis:7-alpine
REDIS_PASSWORD=change-me-long-random-redis-password

# Backups
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/opt/infra/backups
