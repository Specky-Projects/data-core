APP_NAME=data-core
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

DATABASE_URL=postgresql+psycopg://data_core:data_core@postgres:5432/data_core
AUTO_CREATE_TABLES=false

SCHEDULER_ENABLED=true
SCHEDULER_COLLECTORS_ENABLED=true
SCHEDULER_PIPELINE_ENABLED=true
SCHEDULER_DOMAIN_JOBS_ENABLED=true
SCHEDULER_TIMEZONE=America/Sao_Paulo
WORKER_CONCURRENCY=2
WORKER_PIPELINE_INTERVAL_SECONDS=300
COLLECTOR_DEFAULT_MAX_RETRIES=3
COLLECTOR_DEFAULT_RETRY_DELAY_SECONDS=10

# Crypto Coin domain
EXCHANGE=binance
SYMBOL=BTC/USDT
TIMEFRAME=15m
PAPER_TRADING=true
PAPER_INITIAL_BALANCE=10000
STORAGE_URL=sqlite:///runtime-data/crypto_coin.sqlite3
API_KEY=
API_SECRET=
API_PASSPHRASE=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
