generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  free
  premium
  admin

  @@map("user_role")
}

enum SubscriptionPlan {
  free
  premium
  pro
  enterprise

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  active
  canceled
  expired

  @@map("subscription_status")
}

model User {
  id           String @id @default(uuid()) @db.Uuid
  name         String @db.VarChar(150)
  email        String @unique @db.VarChar(255)
  phone        String? @db.VarChar(30)
  passwordHash String @map("password_hash") @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at")
  emailVerificationCode String? @map("email_verification_code") @db.VarChar(12)
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")

  role UserRole @default(free)

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  alerts        Alert[]
  watchlists    Watchlist[]
  subscriptions Subscription[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model Marketplace {
  id String @id @default(uuid()) @db.Uuid

  name    String  @db.VarChar(150)
  slug    String? @unique @db.VarChar(150)
  baseUrl String  @map("base_url") @db.VarChar(255)
  logoUrl String? @map("logo_url")

  active Boolean @default(true)

  offers Offer[]

  @@index([active], map: "idx_marketplaces_active")
  @@map("marketplaces")
}

model Vertical {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(150)
  slug        String   @unique @db.VarChar(150)
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories Category[]
  products   Product[]

  @@index([active], map: "idx_verticals_active")
  @@map("verticals")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  verticalId  String?  @map("vertical_id") @db.Uuid
  name        String   @db.VarChar(150)
  slug        String   @unique @db.VarChar(150)
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vertical Vertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  products Product[]

  @@index([verticalId], map: "idx_categories_vertical_id")
  @@index([active], map: "idx_categories_active")
  @@map("categories")
}

model Brand {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(150)
  normalizedName String   @map("normalized_name") @db.VarChar(150)
  slug           String   @unique @db.VarChar(150)
  logoUrl        String?  @map("logo_url")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([normalizedName], map: "idx_brands_normalized_name")
  @@index([active], map: "idx_brands_active")
  @@map("brands")
}

model Product {
  id         String  @id @default(uuid()) @db.Uuid
  verticalId String? @map("vertical_id") @db.Uuid
  categoryId String? @map("category_id") @db.Uuid
  brandId    String? @map("brand_id") @db.Uuid

  title String @db.VarChar(500)

  normalizedTitle String @map("normalized_title") @db.VarChar(500)

  slug String @unique @db.VarChar(500)

  canonicalName  String? @map("canonical_name") @db.VarChar(500)
  productFamilyName String? @map("product_family_name") @db.VarChar(500)
  productFamilySlug String? @map("product_family_slug") @db.VarChar(500)
  variantLabel   String? @map("variant_label") @db.VarChar(120)
  measureValue   Int?    @map("measure_value")
  measureUnit    String? @map("measure_unit") @db.VarChar(20)
  brand          String? @db.VarChar(150)
  category       String? @db.VarChar(150)
  ean            String? @db.VarChar(32)
  normalizedSize String? @map("normalized_size") @db.VarChar(80)
  quantity       Int?
  unitType       String? @map("unit_type") @db.VarChar(40)
  keywords       String  @default("[]") @db.Text

  imageUrl String? @map("image_url")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  vertical        Vertical?       @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  categoryRef     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandRef        Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  offers          Offer[]
  alerts          Alert[]
  watchlists      Watchlist[]
  reviewSummaries ReviewSummary[]
  marketPatterns  MarketPattern[]

  @@index([verticalId, deletedAt], map: "idx_products_vertical_active")
  @@index([categoryId, deletedAt], map: "idx_products_category_active")
  @@index([brandId, deletedAt], map: "idx_products_brand_active")
  @@index([normalizedTitle], map: "idx_products_normalized_title")
  @@index([ean], map: "idx_products_ean")
  @@index([productFamilySlug], map: "idx_products_family_slug")
  @@index([brand, normalizedSize, quantity], map: "idx_products_canonical_match")
  @@index([brand, category], map: "idx_products_brand_category")
  @@map("products")
}

model Offer {
  id String @id @default(uuid()) @db.Uuid

  productId     String @map("product_id") @db.Uuid
  marketplaceId String @map("marketplace_id") @db.Uuid

  externalId String @map("external_id") @db.VarChar(255)

  price         Decimal  @db.Decimal(10, 2)
  currentPrice  Decimal? @map("current_price") @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  pricePerUnit  Decimal? @map("price_per_unit") @db.Decimal(10, 4)
  freightPrice Decimal @default(0) @map("freight_price") @db.Decimal(10, 2)

  productUrl String @map("product_url")

  availability Boolean @default(true)
  stock Int?
  deliveryAvailable Boolean? @map("delivery_available")
  pickupAvailable Boolean? @map("pickup_available")
  deliveryEstimate String? @map("delivery_estimate") @db.VarChar(120)
  city String? @db.VarChar(120)
  state String? @db.VarChar(2)
  neighborhood String? @db.VarChar(120)
  scrapingStatus String @default("pending") @map("scraping_status") @db.VarChar(40)

  currency String @default("BRL") @db.Char(3)

  updatedAt DateTime @updatedAt @map("updated_at")

  lastCheckedAt DateTime @default(now()) @map("last_checked_at")
  lastScrapedAt DateTime? @map("last_scraped_at")
  lastValidPrice Decimal? @map("last_valid_price") @db.Decimal(10, 2)
  lastValidScrapedAt DateTime? @map("last_valid_scraped_at")

  deletedAt DateTime? @map("deleted_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  priceHistory PriceHistory[]

  @@unique([marketplaceId, externalId], map: "uq_offer_marketplace_external")
  @@index([productId], map: "idx_offers_product_id")
  @@index([marketplaceId], map: "idx_offers_marketplace_id")
  @@index([productId, marketplaceId], map: "idx_offers_product_marketplace")
  @@index([price], map: "idx_offers_price")
  @@index([pricePerUnit], map: "idx_offers_price_per_unit")
  @@index([availability], map: "idx_offers_availability")
  @@index([state, city], map: "idx_offers_region")
  @@index([scrapingStatus], map: "idx_offers_scraping_status")
  @@index([lastCheckedAt], map: "idx_offers_last_checked_at")
  @@index([lastValidScrapedAt], map: "idx_offers_last_valid_scraped_at")
  @@map("offers")
}

model PriceHistory {
  id String @id @default(uuid()) @db.Uuid

  offerId String @map("offer_id") @db.Uuid

  price    Decimal @db.Decimal(10, 2)
  currency String  @default("BRL") @db.Char(3)

  capturedAt DateTime @default(now()) @map("captured_at")

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  // Consecutive duplicate prices must be filtered before insert by reading the
  // latest row for the offer. A plain Prisma unique constraint cannot express
  // "same price only when immediately previous".
  @@index([offerId, capturedAt(sort: Desc)], map: "idx_price_history_offer_captured")
  @@index([capturedAt], map: "idx_price_history_captured_at")
  @@map("price_history")
}

model Watchlist {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  productId String    @map("product_id") @db.Uuid
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "uq_watchlists_user_product")
  @@index([userId, active], map: "idx_watchlists_user_active")
  @@index([productId, active], map: "idx_watchlists_product_active")
  @@map("watchlists")
}

model Alert {
  id String @id @default(uuid()) @db.Uuid

  userId    String @map("user_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  targetPrice Decimal @map("target_price") @db.Decimal(10, 2)

  active Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_alerts_user_id")
  @@index([productId, active], map: "idx_alerts_product_active")
  @@map("alerts")
}

model ScraperHealth {
  id String @id @default(uuid()) @db.Uuid

  marketplace String @unique @db.VarChar(100)

  successCount Int   @default(0) @map("success_count")
  failureCount Int   @default(0) @map("failure_count")
  successRate  Float @default(100) @map("success_rate")

  // Latência média em ms (média móvel simples)
  avgLatencyMs  Float? @map("avg_latency_ms")
  lastLatencyMs Int?   @map("last_latency_ms")

  // Breakdown de erros: JSON { TIMEOUT:5, CAPTCHA:2, ... }
  errorBreakdown String? @map("error_breakdown") @db.Text

  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  lastError     String?   @map("last_error") @db.VarChar(500)
  lastErrorType String?   @map("last_error_type") @db.VarChar(50)

  disabled  Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("scraper_health")
}

// Timeline de scraping — cada linha = 1 tentativa
model ScraperMetric {
  id          String   @id @default(uuid()) @db.Uuid
  marketplace String   @db.VarChar(100)
  capturedAt  DateTime @default(now()) @map("captured_at")
  latencyMs   Int      @map("latency_ms")
  success     Boolean
  errorType   String?  @map("error_type") @db.VarChar(50)

  @@index([marketplace, capturedAt(sort: Desc)], map: "idx_scraper_metrics_mp_time")
  @@map("scraper_metrics")
}

model ScraperDomainMetric {
  id String @id @default(uuid()) @db.Uuid

  domain String @unique @db.VarChar(255)

  total      Int @default(0)
  success    Int @default(0)
  blocks     Int @default(0)
  rateLimits Int @default(0) @map("rate_limits")
  failures   Int @default(0)

  minDelayMs Int @default(3000) @map("min_delay_ms")
  maxDelayMs Int @default(12000) @map("max_delay_ms")

  lastStatusCode Int?     @map("last_status_code")
  lastError      String?  @map("last_error") @db.VarChar(500)
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([lastSeenAt(sort: Desc)], map: "idx_scraper_domain_metrics_seen")
  @@map("scraper_domain_metrics")
}

model ScraperProxyState {
  id String @id @default(uuid()) @db.Uuid

  source    String @db.VarChar(100)
  proxyHash String @map("proxy_hash") @db.VarChar(64)
  label     String? @db.VarChar(150)

  successes Int @default(0)
  failures  Int @default(0)
  banScore  Int @default(0) @map("ban_score")

  cooldownUntil DateTime? @map("cooldown_until")
  lastUsedAt     DateTime? @map("last_used_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([source, proxyHash], map: "uq_scraper_proxy_source_hash")
  @@index([source, cooldownUntil], map: "idx_scraper_proxy_source_cooldown")
  @@map("scraper_proxy_states")
}

model ScraperRunLog {
  id String @id @default(uuid()) @db.Uuid

  marketplace String @db.VarChar(100)
  offerId     String? @map("offer_id") @db.Uuid
  url         String
  finalUrl    String? @map("final_url")

  success    Boolean
  statusCode Int?    @map("status_code")
  errorType  String? @map("error_type") @db.VarChar(50)
  error      String? @db.VarChar(500)
  latencyMs  Int?    @map("latency_ms")
  attempt    Int     @default(1)
  priority   String  @default("scheduler") @db.VarChar(30)

  proxyLabel    String? @map("proxy_label") @db.VarChar(150)
  snapshotPath  String? @map("snapshot_path")
  screenshotPath String? @map("screenshot_path")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([marketplace, createdAt(sort: Desc)], map: "idx_scraper_run_logs_mp_time")
  @@index([success, createdAt(sort: Desc)], map: "idx_scraper_run_logs_success_time")
  @@index([errorType, createdAt(sort: Desc)], map: "idx_scraper_run_logs_error_time")
  @@map("scraper_run_logs")
}

// ─── AI Ops ────────────────────────────────────────────────────────────────────

model AiIncident {
  id String @id @default(uuid()) @db.Uuid

  marketplace  String? @db.VarChar(100)
  incidentType String  @map("incident_type") @db.VarChar(100)
  // low | medium | high | critical
  severity     String  @default("medium") @db.VarChar(20)

  // Dados de entrada usados pela IA
  inputData String @default("{}") @map("input_data") @db.Text

  // Saída da IA
  rootCause    String? @map("root_cause") @db.Text
  suggestions  String  @default("[]") @db.Text // JSON string[]
  confidence   Float?
  aiProvider   String? @map("ai_provider") @db.VarChar(50)
  aiModel      String? @map("ai_model") @db.VarChar(100)
  aiTokensUsed Int?    @map("ai_tokens_used")

  // open | acknowledged | resolved | dismissed
  status         String    @default("open") @db.VarChar(30)
  resolvedAt     DateTime? @map("resolved_at")
  resolutionNote String?   @map("resolution_note") @db.Text

  detectedAt DateTime @default(now()) @map("detected_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([marketplace, status], map: "idx_ai_incidents_mp_status")
  @@index([status, detectedAt(sort: Desc)], map: "idx_ai_incidents_status_time")
  @@map("ai_incidents")
}

// ─── Review Intelligence ───────────────────────────────────────────────────────

model ReviewSummary {
  id String @id @default(uuid()) @db.Uuid

  productId   String @map("product_id") @db.Uuid
  marketplace String @db.VarChar(100)

  rating      Float?
  reviewCount Int?   @map("review_count")
  stars5      Int?   @map("stars_5")
  stars4      Int?   @map("stars_4")
  stars3      Int?   @map("stars_3")
  stars2      Int?   @map("stars_2")
  stars1      Int?   @map("stars_1")

  // JSON: [{ keyword, count, category, sentiment }]
  positiveKeywords String @default("[]") @map("positive_keywords") @db.Text
  negativeKeywords String @default("[]") @map("negative_keywords") @db.Text

  // AI fields (fase 3)
  aiSummary String? @map("ai_summary") @db.Text
  aiPros    String  @default("[]") @map("ai_pros") @db.Text // JSON string[]
  aiCons    String  @default("[]") @map("ai_cons") @db.Text // JSON string[]
  aiVerdict String? @map("ai_verdict") @db.VarChar(255)

  // Trust Score
  trustScore   Int?   @map("trust_score")
  trustFactors String @default("{}") @map("trust_factors") @db.Text // JSON

  scrapedAt    DateTime  @default(now()) @map("scraped_at")
  aiAnalyzedAt DateTime? @map("ai_analyzed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace], map: "uq_review_summary_product_mp")
  @@index([productId], map: "idx_review_summary_product")
  @@map("review_summaries")
}

// ─── Market Intelligence ───────────────────────────────────────────────────────

model MarketPattern {
  id String @id @default(uuid()) @db.Uuid

  productId   String  @map("product_id") @db.Uuid
  marketplace String? @db.VarChar(100) // null = todos os marketplaces
  patternType String  @map("pattern_type") @db.VarChar(50) // seasonal | promo_cycle | volatility

  // Preços médios por mês: { "01": 999.00, "11": 799.00 }
  monthlyAvgPrices String @default("{}") @map("monthly_avg_prices") @db.Text

  // Taxa promocional por mês (0-1)
  monthlyPromoRates String @default("{}") @map("monthly_promo_rates") @db.Text

  // Ciclo promocional
  avgDaysBetweenPromos Int?      @map("avg_days_between_promos")
  lastPromoAt          DateTime? @map("last_promo_at")
  nextPromoEst         DateTime? @map("next_promo_est")

  // Volatilidade
  priceVolatility30d Float? @map("price_volatility_30d")
  priceVolatility90d Float? @map("price_volatility_90d")

  // Tendência
  trendDirection String? @map("trend_direction") @db.VarChar(20) // up | down | stable
  trendStrength  Float?  @map("trend_strength")

  computedAt DateTime @default(now()) @map("computed_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace, patternType], map: "uq_market_pattern")
  @@index([productId], map: "idx_market_pattern_product")
  @@map("market_patterns")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model UserEvent {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String? @map("user_id") @db.Uuid
  sessionId String? @map("session_id") @db.VarChar(100)

  // product_view | alert_created | deal_clicked | upgrade_viewed | ...
  eventType String @map("event_type") @db.VarChar(100)
  payload   String @default("{}") @db.Text // JSON

  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([userId, occurredAt(sort: Desc)], map: "idx_user_events_user_time")
  @@index([eventType, occurredAt(sort: Desc)], map: "idx_user_events_type_time")
  @@map("user_events")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  plan SubscriptionPlan @default(free)

  status SubscriptionStatus @default(active)

  provider String? @db.VarChar(50)

  providerSubscriptionId String? @map("provider_subscription_id") @db.VarChar(255)

  expiresAt DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_subscriptions_user_id")
  @@index([status], map: "idx_subscriptions_status")
  @@index([provider, providerSubscriptionId], map: "idx_subscriptions_provider")
  @@map("subscriptions")
}

model TelegramPost {
  id String @id @default(uuid()) @db.Uuid

  productId String @map("product_id") @db.Uuid
  offerId   String @map("offer_id") @db.Uuid

  chatId String @map("chat_id") @db.VarChar(120)
  messageHash String @map("message_hash") @db.VarChar(64)
  priceSnapshot Decimal @map("price_snapshot") @db.Decimal(10, 2)
  score Float
  status String @default("sent") @db.VarChar(30)
  reason String? @db.VarChar(500)
  payload String @default("{}") @db.Text

  sentAt DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([chatId, messageHash], map: "uq_telegram_posts_chat_hash")
  @@index([productId, sentAt(sort: Desc)], map: "idx_telegram_posts_product_time")
  @@index([offerId, sentAt(sort: Desc)], map: "idx_telegram_posts_offer_time")
  @@index([status, sentAt(sort: Desc)], map: "idx_telegram_posts_status_time")
  @@map("telegram_posts")
}
