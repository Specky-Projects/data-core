{
  "name": "poupi-worker",
  "version": "1.0.0",
  "description": "Worker standalone de scraping — processa a fila BullMQ sem HTTP",
  "private": true,
  "scripts": {
    "build":      "tsc -p tsconfig.json",
    "start":      "node dist/main.js",
